{
  "name": "contextos",
  "private": true,
  "version": "0.2.0",
  "description": "ContextOS — local-first token-reduction engine for AI code editors",
  "workspaces": [
    "apps/extension",
    "apps/landing"
  ],
  "scripts": {
    "build:rust": "cargo build --release",
    "build:ext": "npm --workspace apps/extension run compile",
    "build:landing": "npm --workspace apps/landing run build",
    "build": "npm run build:rust && npm run build:ext && npm run build:landing",
    "dev:ext": "npm --workspace apps/extension run watch",
    "dev:landing": "npm --workspace apps/landing run dev",
    "package:ext": "npm --workspace apps/extension run package",
    "test:rust": "cargo test --workspace",
    "test:ext": "npm --workspace apps/extension run test",
    "test": "npm run test:rust && npm run test:ext"
  }
}
